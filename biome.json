{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "packages/*/src/**/*.ts",
      "apps/web/src/**/*.ts",
      "scripts/**/*.mjs",
      "!**/dist",
      "!**/__snapshots__",
      "!**/*.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": { "enabled": false },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "style": {
        "useTemplate": "off",
        "noNonNullAssertion": "off"
      },
      "complexity": {
        "noUselessEscapeInRegex": "off",
        "useArrowFunction": "off",
        "useLiteralKeys": "off",
        "useOptionalChain": "off"
      },
      "suspicious": {
        "noAssignInExpressions": "off"
      }
    }
  }
}
