// Typecheck aplikacji web (bez emisji — build robi Vite). Rygor z bazy monorepo, plus
// biblioteki DOM i alias „anonimizator" na źródła rdzenia (ten sam, co w vite.config.ts).
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "paths": {
      "anonimizator": ["../../packages/core/src/index.ts"]
    }
  },
  "include": ["src"]
}
