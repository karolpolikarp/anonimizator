// Build rdzenia → dist (z deklaracjami). include jest jawny: to publiczne wejścia npm pakietu;
// surnames.ts i breaker.ts wciągane są tranzytywnie przez importy. Rygor z bazy monorepo.
{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/index.ts", "src/ner-client.ts", "src/llm-client.ts", "src/ner-postprocess.ts"]
}
